T*
(### Booking API Controller) Tj
T*
() Tj
T*
() Tj
T*
([java]) Tj
T*
(@PostMapping) Tj
T*
(@ResponseStatus\(HttpStatus.CREATED\)) Tj
T*
(public Booking createBooking\(@Valid @RequestBody BookingRequest request, Principal principal\) {) Tj
T*
(  var user = userRepository.findByEmail\(principal.getName\(\)\)) Tj
T*
(      .orElseThrow\(\(\) -> new ResponseStatusException\(HttpStatus.UNAUTHORIZED, "User not found."\)\);) Tj
T*
() Tj
T*
(  var booking = new Booking\(\);) Tj
T*
(  booking.setUser\(user\);) Tj
T*
(  booking.setStatus\(BookingStatus.CONFIRMED\);) Tj
T*
(  booking.setGuestName\(request.guestName\(\)\);) Tj
T*
(  booking.setEmail\(request.email\(\)\);) Tj
T*
() Tj
T*
(  attachProduct\(booking, request\);) Tj
T*
(  return bookingRepository.save\(booking\);) Tj
T*
(}) Tj
T*
() Tj
T*
(### Chatbot City Matching) Tj
T*
() Tj
T*
() Tj
T*
([typescript]) Tj
T*
(private findGuide\(city: string\): CityGuide | undefined {) Tj
T*
(  const normalizedCity = this.normalize\(city\);) Tj
T*
(  return CITY_GUIDES.find\(\(guide\) =>) Tj
T*
(    guide.aliases.some\(\(alias\) => this.normalize\(alias\) === normalizedCity\)) Tj
T*
(  \);) Tj
T*
(}) Tj
T*
