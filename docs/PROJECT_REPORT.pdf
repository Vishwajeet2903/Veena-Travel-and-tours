T*
(  Angular --> Services[Angular Services]) Tj
T*
(  Services --> API[Spring Boot REST API]) Tj
T*
(  API --> Security[Spring Security + JWT]) Tj
T*
(  API --> JPA[JPA Repositories]) Tj
T*
(  JPA --> DB[\(MySQL Database\)]) Tj
T*
() Tj
T*
